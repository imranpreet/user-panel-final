# Environment Variables Template
# Copy this file as .env and update values

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Base URL for API endpoints
# Development: http://localhost:5000/api
# Production: https://api.yourbackend.com/api
REACT_APP_API_URL=http://localhost:5000/api

# API request timeout (in milliseconds)
REACT_APP_API_TIMEOUT=30000

# Environment (development | production | staging)
REACT_APP_ENV=development

# =============================================================================
# AUTHENTICATION
# =============================================================================

# JWT Token storage key
REACT_APP_TOKEN_KEY=authToken

# Token expiration time (in seconds)
REACT_APP_TOKEN_EXPIRATION=86400

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable analytics
REACT_APP_ANALYTICS_ENABLED=true

# Enable/disable error reporting
REACT_APP_ERROR_REPORTING=true

# Enable/disable debug mode
REACT_APP_DEBUG_MODE=false

# =============================================================================
# THIRD PARTY SERVICES
# =============================================================================

# Google Analytics ID (optional)
REACT_APP_GOOGLE_ANALYTICS_ID=

# Sentry Error Tracking (optional)
REACT_APP_SENTRY_DSN=

# =============================================================================
# APP CONFIGURATION
# =============================================================================

# Application name
REACT_APP_NAME=User Panel

# Application version
REACT_APP_VERSION=1.0.0

# Application title
REACT_APP_TITLE=Singulart User Panel

# =============================================================================
# SECURITY
# =============================================================================

# Enable HTTPS only (production)
REACT_APP_HTTPS_ONLY=false

# API rate limit (requests per minute)
REACT_APP_RATE_LIMIT=100

# =============================================================================
# PAGINATION
# =============================================================================

# Default items per page
REACT_APP_DEFAULT_PAGE_SIZE=10

# Maximum items per page
REACT_APP_MAX_PAGE_SIZE=100

# =============================================================================
# FILE UPLOAD
# =============================================================================

# Maximum file size for uploads (in MB)
REACT_APP_MAX_FILE_SIZE=5

# Allowed file types for profile picture (comma-separated)
REACT_APP_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Enable data caching
REACT_APP_CACHING_ENABLED=true

# Cache duration (in seconds)
REACT_APP_CACHE_DURATION=300

# =============================================================================
# CURRENCY & LOCALIZATION
# =============================================================================

# Default currency
REACT_APP_DEFAULT_CURRENCY=INR

# Default language
REACT_APP_DEFAULT_LANGUAGE=en

# Default timezone
REACT_APP_DEFAULT_TIMEZONE=Asia/Kolkata

# Date format (MM/DD/YYYY | DD/MM/YYYY | YYYY-MM-DD)
REACT_APP_DATE_FORMAT=MM/DD/YYYY

# =============================================================================
# LOGGING
# =============================================================================

# Log level (error | warn | info | debug)
REACT_APP_LOG_LEVEL=info

# Enable console logging
REACT_APP_CONSOLE_LOGGING=true

# =============================================================================
# ANALYTICS CONFIGURATION
# =============================================================================

# Dashboard refresh interval (in seconds)
REACT_APP_DASHBOARD_REFRESH_INTERVAL=60

# Orders refresh interval (in seconds)
REACT_APP_ORDERS_REFRESH_INTERVAL=30

# =============================================================================
# NOTIFICATION CONFIGURATION
# =============================================================================

# Default notification duration (in milliseconds)
REACT_APP_NOTIFICATION_DURATION=3000

# Max notifications to display
REACT_APP_MAX_NOTIFICATIONS=5

# =============================================================================
# PASSWORD REQUIREMENTS
# =============================================================================

# Minimum password length
REACT_APP_MIN_PASSWORD_LENGTH=8

# Require uppercase letters in password
REACT_APP_PASSWORD_REQUIRE_UPPERCASE=true

# Require lowercase letters in password
REACT_APP_PASSWORD_REQUIRE_LOWERCASE=true

# Require numbers in password
REACT_APP_PASSWORD_REQUIRE_NUMBERS=true

# Require special characters in password
REACT_APP_PASSWORD_REQUIRE_SPECIAL=true

# =============================================================================
# FORM VALIDATION
# =============================================================================

# Maximum length for input fields
REACT_APP_MAX_INPUT_LENGTH=255

# Maximum length for text areas
REACT_APP_MAX_TEXTAREA_LENGTH=1000

# =============================================================================
# API ENDPOINTS (Optional - if using different endpoints)
# =============================================================================

# User endpoints
# REACT_APP_API_USER_PROFILE=/user/profile
# REACT_APP_API_USER_ADDRESSES=/user/addresses
# REACT_APP_API_USER_ORDERS=/user/orders

# Payment endpoints
# REACT_APP_API_PAYMENTS=/user/payments

# Notification endpoints
# REACT_APP_API_NOTIFICATIONS=/user/notifications

# =============================================================================
# STAGING / TESTING
# =============================================================================

# Use mock data (for testing without backend)
REACT_APP_USE_MOCK_DATA=false

# Mock data delay (in milliseconds)
REACT_APP_MOCK_DATA_DELAY=1000

# =============================================================================
# NOTES
# =============================================================================

# 1. Never commit .env file with sensitive data to git
# 2. Use .env.example for git and .env.local for local development
# 3. For production, set environment variables in deployment platform
# 4. Update REACT_APP_API_URL based on your backend server URL
# 5. All REACT_APP_* variables must start with REACT_APP_ prefix
# 6. Numeric values should not be quoted
# 7. String values should be quoted
# 8. Restart development server after changing .env file

# =============================================================================
# QUICK SETUP
# =============================================================================

# For local development with local backend:
# REACT_APP_API_URL=http://localhost:5000/api
# REACT_APP_ENV=development

# For staging with staging backend:
# REACT_APP_API_URL=https://staging-api.yourbackend.com/api
# REACT_APP_ENV=staging

# For production with production backend:
# REACT_APP_API_URL=https://api.yourbackend.com/api
# REACT_APP_ENV=production
